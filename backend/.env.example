# ─────────────────────────────────────────────────────────
# BACKEND .env — Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Port the server runs on
PORT=5000

# Your secret key for signing JWT tokens — make it long and random
# Example: openssl rand -base64 32
JWT_SECRET=replace_this_with_a_long_random_string_abc123

# Your admin password HASHED with bcrypt
# Run this in the backend folder to generate it:
#   node -e "const b=require('bcryptjs'); b.hash('your_password',10).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2a$10$replacethiswithyourrealbcrypthash

# URL of your frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Set to 'production' when deploying
NODE_ENV=development
